# ── Kwentong Multo — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# OpenRouter — LLM script generation (Tagalog horror scripts)
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Pexels — free horror/scared face photos for thumbnails
# Get key at: https://www.pexels.com/api
PEXELS_API_KEY=your_pexels_key_here

# YouTube Data API v3 OAuth — for video uploads
# Setup: https://console.cloud.google.com → APIs & Services → OAuth 2.0
# Run: python oauth_setup.py  (once, locally) to generate token.json
# Then store as GitHub Secrets:
#   YOUTUBE_TOKEN_JSON        = contents of token.json
#   YOUTUBE_CREDENTIALS_JSON  = contents of credentials.json
YOUTUBE_TOKEN_JSON=
YOUTUBE_CREDENTIALS_JSON=

# Telegram bot notifications (optional)
# Create a bot at https://t.me/BotFather, get the token and your chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
