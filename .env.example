# ── Drama Desk — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your keys
# Never commit .env to git

# OpenRouter — script generation via Claude 3.5 Sonnet
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# Pexels — free B-roll video downloads
# Get key at: https://www.pexels.com/api
PEXELS_API_KEY=your_pexels_key_here

# Pixabay — optional fallback B-roll (free)
# Get key at: https://pixabay.com/api/docs
PIXABAY_API_KEY=

# YouTube Data API v3 OAuth — for video uploads
# Setup: https://console.cloud.google.com → APIs & Services → OAuth
# Run oauth_setup.py once locally to generate token.json
# Then store contents as GitHub Secrets:
#   YOUTUBE_TOKEN_JSON        = contents of token.json
#   YOUTUBE_CREDENTIALS_JSON  = contents of credentials.json
